{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse.elevendots.dev/schemas/section.schema.json",
  "title": "Pulse Mobile Section Feed",
  "description": "Full article list for a single section. Same structure as home.json.",
  "type": "object",
  "required": ["generated_at", "articles"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "articles": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/Article" }
    }
  },
  "$defs": {
    "Article": {
      "type": "object",
      "required": [
        "id", "title", "source", "source_url", "section", "subsection",
        "published", "published_confidence", "freshness_score", "intro",
        "url", "access", "tier"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z]+-[a-f0-9]{12}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "section": {
          "type": "string",
          "enum": ["tech", "science", "philosophy", "world", "research", "misc"]
        },
        "subsection": {
          "type": "string"
        },
        "published": {
          "type": "string",
          "format": "date-time"
        },
        "published_confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "freshness_score": {
          "type": "integer",
          "minimum": 0
        },
        "intro": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "access": {
          "type": "string",
          "enum": ["free", "metered", "paywall"]
        },
        "tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        }
      }
    }
  }
}
